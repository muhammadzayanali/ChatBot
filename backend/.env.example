# Copy this file to .env and add your real values.
# .env is in .gitignore — never commit it.

# Required: your OpenAI API key (paste your key after the =)
OPENAI_API_KEY=

# Optional: Django (for production)
# DJANGO_SECRET_KEY=your-secret-key
# DJANGO_DEBUG=False

# Optional: MySQL for production
# DATABASE_URL=mysql+pymysql://user:password@localhost/braelo

# Optional: GPT and knowledge
# GPT_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# KNOWLEDGE_SIMILARITY_THRESHOLD=0.62
# DOCX_DATA_DIR=../
